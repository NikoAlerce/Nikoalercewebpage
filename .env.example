# Endpoint GraphQL p\u00fablico de Objkt (Tezos)
NEXT_PUBLIC_OBJKT_GRAPHQL=https://data.objkt.com/v3/graphql

# Aliases por defecto (separar con coma)
NEXT_PUBLIC_OBJKT_ALIASES=nikoalerce,sidequest

# Wallet override opcional (tz1...). Si est\u00e1 vac\u00edo, se usa el alias.
NEXT_PUBLIC_OBJKT_WALLET=

# Beacon: URL p\u00fablica del sitio (fallback si window no est\u00e1 disponible en init).
# NEXT_PUBLIC_SITE_URL=https://nikoalercewebpage.vercel.app

# Beacon / WalletConnect (opcional). Project ID de https://cloud.walletconnect.com — mejora pairing m\u00f3vil.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Icono del dApp en el modal de Beacon (opcional, URL absoluta).
# NEXT_PUBLIC_BEACON_ICON_URL=
